                    ))}
                </ul>
            </div>

            <!-- Contacts -->
            <div>
                <h3 class="text-base font-semibold mb-4 pb-2 border-b border-gray-700">{text.footCont}</h3>
                <div class="space-y-3">
                    <a href="tel:+37360680819" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors group">
                        <i class="ph-fill ph-phone text-orange-400 text-xl flex-shrink-0"></i>
                        <span class="text-lg font-bold">+373 60 680 819</span>
                    </a>
                    <a href="mailto:proacoperis54@gmail.com" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors group">
                        <i class="ph ph-envelope text-orange-400 text-xl flex-shrink-0"></i>
                        <span class="text-sm">proacoperis54@gmail.com</span>
                    </a>
                    <div class="flex flex-wrap gap-2 pt-1">
                        <a href="https://wa.me/37360680819" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-1.5 bg-green-600/20 hover:bg-green-600/30 text-green-400 border border-green-600/30 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <i class="ph ph-whatsapp-logo text-base"></i> WhatsApp
                        </a>
                        <a href="viber://chat?number=%2B37360680819"
                           class="flex items-center gap-1.5 bg-purple-600/20 hover:bg-purple-600/30 text-purple-400 border border-purple-600/30 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <i class="ph ph-chat-circle text-base"></i> Viber
                        </a>
                        <a href="https://t.me/+37360680819" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-1.5 bg-sky-600/20 hover:bg-sky-600/30 text-sky-400 border border-sky-600/30 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <i class="ph ph-telegram-logo text-base"></i> Telegram
                        </a>
                        <a href="https://www.facebook.com/profile.php?id=61581585747077" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-1.5 bg-blue-600/20 hover:bg-blue-600/30 text-blue-400 border border-blue-600/30 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <i class="ph ph-facebook-logo text-base"></i> Facebook
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-3 text-gray-500 text-sm">
            <p>&copy; {currentYear} ProAcoperis.md. {text.footRights}</p>
            <p class="flex items-center gap-2">
                <i class="ph-fill ph-certificate text-orange-400"></i>
                {text.footMade}
            </p>
        </div>
    </div>
</footer>

<!-- Sticky messenger buttons -->
<div class="fixed bottom-8 right-3 sm:bottom-8 sm:right-4 z-50 flex flex-col gap-2 sm:gap-2.5">
    <!-- Phone call button — mobile prominent -->
    <a href="tel:+37360680819"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-orange-500 hover:bg-orange-600 rounded-full flex items-center justify-center shadow-lg shadow-orange-500/50 hover:shadow-orange-500/70 transition-all duration-200 hover:scale-110"
       aria-label="Позвонить / Sunați">
        <i class="ph-fill ph-phone text-white text-lg sm:text-xl"></i>
    </a>
    <a href="https://wa.me/37360680819" target="_blank" rel="noopener noreferrer"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-[#25D366] hover:bg-[#1ebe5d] rounded-full flex items-center justify-center shadow-lg shadow-green-500/40 hover:shadow-green-500/60 transition-all duration-200 hover:scale-110"
       aria-label="WhatsApp">
        <i class="ph ph-whatsapp-logo text-white text-lg sm:text-xl"></i>
    </a>
    <a href="viber://chat?number=%2B37360680819"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-[#7360F2] hover:bg-[#6250e0] rounded-full flex items-center justify-center shadow-lg shadow-purple-500/40 hover:shadow-purple-500/60 transition-all duration-200 hover:scale-110"
       aria-label="Viber">
        <i class="ph ph-chat-circle-dots text-white text-lg sm:text-xl"></i>
    </a>
    <a href="https://t.me/+37360680819" target="_blank" rel="noopener noreferrer"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-[#29A8EB] hover:bg-[#1a96d8] rounded-full flex items-center justify-center shadow-lg shadow-sky-500/40 hover:shadow-sky-500/60 transition-all duration-200 hover:scale-110"
       aria-label="Telegram">
        <i class="ph ph-telegram-logo text-white text-lg sm:text-xl"></i>
    </a>
    <a href="https://www.facebook.com/profile.php?id=61581585747077" target="_blank" rel="noopener noreferrer"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-[#1877F2] hover:bg-[#0d6ce0] rounded-full flex items-center justify-center shadow-lg shadow-blue-500/40 hover:shadow-blue-500/60 transition-all duration-200 hover:scale-110"
       aria-label="Facebook">
        <i class="ph ph-facebook-logo text-white text-lg sm:text-xl"></i>
    </a>
</div>

<!-- ═══════════════════════════════════════════════════════ COOKIE BANNER -->
<div id="cookie-banner" class="hidden fixed bottom-0 left-0 right-0 z-[200] bg-gray-950/95 backdrop-blur-md border-t border-white/10 shadow-2xl">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between">
        <p class="text-gray-300 text-sm leading-relaxed max-w-2xl" id="cookie-text"></p>
        <div class="flex items-center gap-3 flex-shrink-0">
            <button id="cookie-decline"
                class="px-4 py-2 rounded-xl text-sm font-semibold text-gray-400 hover:text-white border border-white/15 hover:border-white/30 transition-colors">
                <span class="ru-text">Отказаться</span><span class="ro-text hidden">Refuz</span>
            </button>
            <button id="cookie-accept"
                class="px-5 py-2 rounded-xl text-sm font-bold bg-orange-500 hover:bg-orange-600 text-white transition-colors shadow-md shadow-orange-600/30">
                <span class="ru-text">Принять</span><span class="ro-text hidden">Accept</span>
            </button>
        </div>
    </div>
</div>

<!-- Phosphor icons: loaded after page renders, non-blocking -->
<script src="https://unpkg.com/@phosphor-icons/web@2.1.1" defer></script>

<!-- Page loader: hide after min 1.2s AND window.load -->
<script is:inline>
    (function() {
        var loader = document.getElementById('page-loader');
        var MIN_MS = 1200;
        var start  = Date.now();
        function hide() {
            var wait = Math.max(0, MIN_MS - (Date.now() - start));
            setTimeout(function() {
                loader.classList.add('loader-done');
                setTimeout(function() { if (loader.parentNode) loader.parentNode.removeChild(loader); }, 500);
            }, wait);
        }
        if (document.readyState === 'complete') { hide(); }
        else { window.addEventListener('load', hide, { once: true }); }
    })();
</script>

<script is:inline>
    const btn  = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');

    btn.addEventListener('click', () => {
        const isHidden = menu.classList.toggle('hidden');
        icon.className = isHidden ? 'ph ph-list text-3xl' : 'ph ph-x text-3xl';
    });

    // Lazy image fade-in: mark as loaded once fetched
    document.querySelectorAll('img[loading="lazy"]').forEach(img => {
        if (img.complete) {
            img.classList.add('loaded');
        } else {
            img.addEventListener('load', () => img.classList.add('loaded'), { once: true });
        }
    });


    // Cookie consent banner
    (function() {
        if (localStorage.getItem('cookieConsent')) return;
        var banner = document.getElementById('cookie-banner');
        var isRo   = document.documentElement.lang === 'ro';
        document.getElementById('cookie-text').textContent = isRo
            ? 'Folosim cookie-uri pentru analitica anonimă (Google Analytics) pentru a înțelege cum utilizați site-ul. Nu colectăm date personale fără acordul dvs.'
            : 'Мы используем файлы cookie для анонимной аналитики (Google Analytics), чтобы понимать как вы используете сайт. Личные данные без вашего согласия не собираются.';
        banner.querySelectorAll('.ru-text').forEach(function(el){ el.classList.toggle('hidden', isRo); });
        banner.querySelectorAll('.ro-text').forEach(function(el){ el.classList.toggle('hidden', !isRo); });
        banner.classList.remove('hidden');
        document.getElementById('cookie-accept').addEventListener('click', function() {
            localStorage.setItem('cookieConsent', 'yes');
            banner.remove();
            loadGA();
        });
        document.getElementById('cookie-decline').addEventListener('click', function() {
            localStorage.setItem('cookieConsent', 'no');
            banner.remove();
        });
    })();

</script>
</body>
</html>
