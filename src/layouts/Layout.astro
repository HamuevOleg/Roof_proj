---
import '../styles/global.css';
import { ui, getServicesData } from '../data/i18n.js';

const { lang, title } = Astro.props;
const text = ui[lang];
const base = import.meta.env.BASE_URL;
const services = getServicesData(lang, base);
const currentYear = new Date().getFullYear(); // always trailing slash from astro.config base: '/Roof_proj/'
const rawPath = Astro.url.pathname.startsWith(base.slice(0, -1)) ? Astro.url.pathname.slice(base.length - 1) : Astro.url.pathname;
const currentPath = rawPath.replace(`/${lang}`, '') || '/';
const getLangLink = (targetLang) => `${base}${targetLang}${currentPath}`;

const navItems = [
    { id: 'home',      label: text.nav.home,      href: `${base}${lang}/` },
    { id: 'services',  label: text.nav.services,  href: `${base}${lang}/services` },
    { id: 'portfolio', label: text.nav.portfolio,  href: `${base}${lang}/portfolio` },
    { id: 'about',     label: text.nav.about,      href: `${base}${lang}/about` },
    { id: 'contacts',  label: text.nav.contacts,   href: `${base}${lang}/contacts` }
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} - ProAcoperis.md</title>

    <!-- Performance: preconnect to external origins -->
    <link rel="preconnect" href="https://unpkg.com" crossorigin>
    <link rel="dns-prefetch" href="https://www.youtube.com">
    <link rel="dns-prefetch" href="https://img.youtube.com">

    <!-- Phosphor icons: defer so it doesn't block render -->
    <link rel="preload" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.css"></noscript>
</head>
<body class="font-sans bg-white text-gray-900 flex flex-col min-h-screen">

<!-- ═══════════════════════════════════════════════════════ HEADER -->
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md shadow-sm">

    <!-- Accent bar -->
    <div class="h-1 bg-gradient-to-r from-blue-800 via-blue-500 to-cyan-400"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">

            <!-- Logo -->
            <a href={`${base}${lang}/`} class="flex items-center gap-3 flex-shrink-0 group">
                <div class="bg-gradient-to-br from-blue-600 to-blue-800 text-white p-2.5 rounded-xl flex items-center justify-center shadow-md shadow-blue-600/30 group-hover:shadow-blue-600/50 group-hover:scale-105 transition-all duration-300">
                    <i class="ph ph-buildings text-2xl"></i>
                </div>
                <div>
                    <p class="text-2xl font-black leading-tight tracking-tight">
                        <span class="text-gray-900">Pro</span><span class="text-blue-600">Acoperis</span><span class="text-cyan-500">.md</span>
                    </p>
                    <p class="text-xs text-gray-400 uppercase tracking-widest font-semibold">{text.brandExpert}</p>
                </div>
            </a>

            <!-- Desktop nav -->
            <nav class="hidden lg:flex items-center gap-0.5">
                {navItems.map(item => (
                    <a href={item.href} class="relative px-4 py-2 text-sm font-semibold text-gray-600 hover:text-blue-600 transition-colors rounded-lg hover:bg-blue-50 group/nav">
                        {item.label}
                        <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-0 group-hover/nav:w-3/5 h-0.5 bg-blue-500 rounded-full transition-all duration-300"></span>
                    </a>
                ))}
            </nav>

            <!-- Desktop actions -->
            <div class="hidden lg:flex items-center gap-3">
                <div class="flex items-center bg-gray-100 rounded-full p-1">
                    <a href={getLangLink('ru')} class={`w-10 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ru' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-900'}`}>RU</a>
                    <a href={getLangLink('ro')} class={`w-10 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ro' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-900'}`}>RO</a>
                </div>
                <a href="tel:+37360000000" class="flex items-center gap-2 bg-gray-50 hover:bg-gray-100 border border-gray-200 text-gray-800 px-4 py-2 rounded-full font-medium transition-colors text-sm">
                    <i class="ph-fill ph-phone text-blue-600 text-base"></i>
                    +373 60 000 000
                </a>
                <a href={`${base}${lang}/contacts`} class="bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white px-5 py-2.5 rounded-full font-semibold transition-all whitespace-nowrap shadow-md shadow-blue-600/30 hover:shadow-blue-600/50 text-sm">
                    {text.freeEst}
                </a>
            </div>

            <!-- Mobile actions -->
            <div class="lg:hidden flex items-center gap-2">
                <div class="flex items-center bg-gray-100 rounded-full p-1">
                    <a href={getLangLink('ru')} class={`w-9 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ru' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500'}`}>RU</a>
                    <a href={getLangLink('ro')} class={`w-9 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ro' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500'}`}>RO</a>
                </div>
                <button id="mobile-menu-toggle" class="text-gray-600 hover:text-blue-600 focus:outline-none flex items-center justify-center w-10 h-10 rounded-xl hover:bg-blue-50 transition-colors">
                    <i class="ph ph-list text-3xl" id="menu-icon"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 absolute w-full left-0 shadow-xl">
        <div class="px-4 pt-3 pb-6 space-y-1">
            {navItems.map(item => (
                <a href={item.href} class="flex items-center px-4 py-3 rounded-xl text-base font-semibold text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors">
                    {item.label}
                </a>
            ))}
            <div class="pt-3 border-t border-gray-100 space-y-2.5 mt-2">
                <a href="tel:+37360000000" class="flex items-center justify-center gap-2 w-full bg-gray-50 border border-gray-200 text-gray-900 px-4 py-3 rounded-xl font-medium">
                    <i class="ph-fill ph-phone text-blue-600 text-xl"></i>
                    +373 60 000 000
                </a>
                <a href={`${base}${lang}/contacts`} class="flex items-center justify-center w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white px-4 py-3.5 rounded-xl font-semibold shadow-md shadow-blue-600/25 transition-all">
                    {text.freeEst}
                </a>
            </div>
        </div>
    </div>
</header>

<main class="flex-grow">
    <slot />
</main>

<!-- ═══════════════════════════════════════════════════════ FOOTER -->
<footer class="bg-gray-900 text-white pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 mb-12">

            <!-- Brand -->
            <div>
                <div class="flex items-center gap-2 mb-4">
                    <div class="bg-white text-blue-600 p-1.5 rounded-lg flex items-center justify-center">
                        <i class="ph ph-buildings text-xl"></i>
                    </div>
                    <span class="text-xl font-black"><span class="text-white">Pro</span><span class="text-blue-400">Acoperis</span><span class="text-cyan-400">.md</span></span>
                </div>
                <p class="text-gray-400 text-sm leading-relaxed">{text.footDesc}</p>
            </div>

            <!-- Nav -->
            <div>
                <h3 class="text-base font-semibold mb-4 pb-2 border-b border-gray-700">{text.footNav}</h3>
                <ul class="space-y-2.5">
                    {navItems.map(item => (
                        <li><a href={item.href} class="text-gray-400 hover:text-white transition-colors text-sm">{item.label}</a></li>
                    ))}
                </ul>
            </div>

            <!-- Services -->
            <div>
                <h3 class="text-base font-semibold mb-4 pb-2 border-b border-gray-700">{text.footServ}</h3>
                <ul class="space-y-2.5">
                    {services.slice(0, 4).map(service => (
                        <li class="text-gray-400 text-sm">{service.title}</li>
                    ))}
                </ul>
            </div>

            <!-- Contacts -->
            <div>
                <h3 class="text-base font-semibold mb-4 pb-2 border-b border-gray-700">{text.footCont}</h3>
                <a href="tel:+37360000000" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors group">
                    <i class="ph-fill ph-phone text-blue-400 text-xl flex-shrink-0"></i>
                    <span class="text-lg font-bold">+373 60 000 000</span>
                </a>
            </div>
        </div>

        <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-3 text-gray-500 text-sm">
            <p>&copy; {currentYear} ProAcoperis.md. {text.footRights}</p>
            <p>{text.footMade}</p>
        </div>
    </div>
</footer>

<!-- Phosphor icons: loaded after page renders, non-blocking -->
<script src="https://unpkg.com/@phosphor-icons/web@2.1.1" defer></script>

<script is:inline>
    const btn  = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');

    btn.addEventListener('click', () => {
        const isHidden = menu.classList.toggle('hidden');
        icon.className = isHidden ? 'ph ph-list text-3xl' : 'ph ph-x text-3xl';
    });
</script>
</body>
</html>
