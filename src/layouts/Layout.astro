---
import '../styles/global.css';
import { ui, getServicesData } from '../data/i18n.js';

const { lang, title } = Astro.props;
const text = ui[lang];
const base = import.meta.env.BASE_URL;
const services = getServicesData(lang, base);
const currentYear = new Date().getFullYear(); // always trailing slash from astro.config base: '/Roof_proj/'
const rawPath = Astro.url.pathname.startsWith(base.slice(0, -1)) ? Astro.url.pathname.slice(base.length - 1) : Astro.url.pathname;
const currentPath = rawPath.replace(`/${lang}`, '') || '/';
const getLangLink = (targetLang) => `${base}${targetLang}${currentPath}`;

const navItems = [
    { id: 'home',      label: text.nav.home,      href: `${base}${lang}/` },
    { id: 'services',  label: text.nav.services,  href: `${base}${lang}/services` },
    { id: 'portfolio', label: text.nav.portfolio,  href: `${base}${lang}/portfolio` },
    { id: 'about',     label: text.nav.about,      href: `${base}${lang}/about` },
    { id: 'contacts',  label: text.nav.contacts,   href: `${base}${lang}/contacts` }
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} - ProAcoperis.md</title>

    <!-- Performance: preconnect to external origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://unpkg.com" crossorigin>
    <link rel="dns-prefetch" href="https://www.youtube.com">
    <link rel="dns-prefetch" href="https://img.youtube.com">

    <!-- Phosphor icons: defer so it doesn't block render -->
    <link rel="preload" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.css"></noscript>
</head>
<body class="font-sans bg-white text-gray-900 flex flex-col min-h-screen">

<!-- ═══════════════════════════════════════════════════════ HEADER -->
<header id="site-header" class="sticky top-0 z-50 bg-gray-900 backdrop-blur-md shadow-lg shadow-black/30 transition-all duration-300">

    <!-- Accent bar — orange -->
    <div class="h-1 bg-gradient-to-r from-orange-600 via-orange-500 to-amber-400"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20 transition-all duration-300" id="header-inner">

            <!-- Logo -->
            <a href={`${base}${lang}/`} class="flex items-center gap-3 flex-shrink-0 group">
                <div class="bg-gradient-to-br from-orange-500 to-orange-700 text-white p-2.5 rounded-xl flex items-center justify-center shadow-md shadow-orange-600/40 group-hover:shadow-orange-600/60 group-hover:scale-105 transition-all duration-300">
                    <i class="ph ph-buildings text-2xl"></i>
                </div>
                <div>
                    <p class="text-2xl font-black leading-tight tracking-tight font-heading">
                        <span class="text-white">Pro</span><span class="text-orange-400">Acoperis</span><span class="text-amber-400">.md</span>
                    </p>
                    <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold">{text.brandExpert}</p>
                </div>
            </a>

            <!-- Desktop nav -->
            <nav class="hidden xl:flex items-center gap-0.5">
                {navItems.map(item => (
                    <a href={item.href} class="relative px-4 py-2 text-sm font-semibold text-gray-300 hover:text-white transition-colors rounded-lg hover:bg-white/10 group/nav">
                        {item.label}
                        <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-0 group-hover/nav:w-3/5 h-0.5 bg-orange-400 rounded-full transition-all duration-300"></span>
                    </a>
                ))}
            </nav>

            <!-- Desktop actions -->
            <div class="hidden xl:flex items-center gap-3">
                <div class="flex items-center bg-white/10 rounded-full p-1">
                    <a href={getLangLink('ru')} class={`w-10 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ru' ? 'bg-white/20 text-orange-400' : 'text-gray-400 hover:text-white'}`}>RU</a>
                    <a href={getLangLink('ro')} class={`w-10 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ro' ? 'bg-white/20 text-orange-400' : 'text-gray-400 hover:text-white'}`}>RO</a>
                </div>
                <a href="tel:+37360680819" class="flex items-center gap-2 bg-white/8 hover:bg-white/15 border border-white/15 text-white px-4 py-2 rounded-full font-medium transition-colors text-sm">
                    <i class="ph-fill ph-phone text-orange-400 text-base"></i>
                    +373 60 680 819
                </a>
                <a href={`${base}${lang}/contacts`} class="bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white px-5 py-2.5 rounded-full font-semibold transition-all whitespace-nowrap shadow-md shadow-orange-600/40 hover:shadow-orange-600/60 text-sm">
                    {text.freeEst}
                </a>
            </div>

            <!-- Mobile actions -->
            <div class="xl:hidden flex items-center gap-2">
                <div class="flex items-center bg-white/10 rounded-full p-1">
                    <a href={getLangLink('ru')} class={`w-9 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ru' ? 'bg-white/20 text-orange-400' : 'text-gray-400'}`}>RU</a>
                    <a href={getLangLink('ro')} class={`w-9 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ro' ? 'bg-white/20 text-orange-400' : 'text-gray-400'}`}>RO</a>
                </div>
                <button id="mobile-menu-toggle" class="text-gray-400 hover:text-white focus:outline-none flex items-center justify-center w-10 h-10 rounded-xl hover:bg-white/10 transition-colors">
                    <i class="ph ph-list text-3xl" id="menu-icon"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden xl:hidden bg-gray-900 border-t border-white/10 absolute w-full left-0 shadow-2xl shadow-black/50">
        <div class="px-4 pt-3 pb-6 space-y-1">
            {navItems.map(item => (
                <a href={item.href} class="flex items-center px-4 py-3 rounded-xl text-base font-semibold text-gray-300 hover:bg-white/10 hover:text-white transition-colors">
                    {item.label}
                </a>
            ))}
            <div class="pt-3 border-t border-white/10 space-y-2.5 mt-2">
                <a href="tel:+37360680819" class="flex items-center justify-center gap-2 w-full bg-white/10 border border-white/20 text-white px-4 py-3 rounded-xl font-medium">
                    <i class="ph-fill ph-phone text-orange-400 text-xl"></i>
                    +373 60 680 819
                </a>
                <a href={`${base}${lang}/contacts`} class="flex items-center justify-center w-full bg-gradient-to-r from-orange-500 to-orange-600 text-white px-4 py-3.5 rounded-xl font-semibold shadow-md shadow-orange-600/30 transition-all">
                    {text.freeEst}
                </a>
            </div>
        </div>
    </div>
</header>

<main class="flex-grow">
    <slot />
</main>

<!-- ═══════════════════════════════════════════════════════ FOOTER -->
<footer class="bg-gray-900 text-white pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 mb-12">

            <!-- Brand -->
            <div>
                <div class="flex items-center gap-2 mb-4">
                    <div class="bg-orange-500/20 text-orange-400 p-1.5 rounded-lg flex items-center justify-center">
                        <i class="ph ph-buildings text-xl"></i>
                    </div>
                    <span class="text-xl font-black font-heading"><span class="text-white">Pro</span><span class="text-orange-400">Acoperis</span><span class="text-amber-400">.md</span></span>
                </div>
                <p class="text-gray-400 text-sm leading-relaxed mb-4">{text.footDesc}</p>
                <p class="text-gray-600 text-xs">{text.footLegal}</p>
            </div>

            <!-- Nav -->
            <div>
                <h3 class="text-base font-semibold mb-4 pb-2 border-b border-gray-700">{text.footNav}</h3>
                <ul class="space-y-2.5">
                    {navItems.map(item => (
                        <li><a href={item.href} class="text-gray-400 hover:text-white transition-colors text-sm">{item.label}</a></li>
                    ))}
                </ul>
            </div>

            <!-- Services -->
            <div>
                <h3 class="text-base font-semibold mb-4 pb-2 border-b border-gray-700">{text.footServ}</h3>
                <ul class="space-y-2.5">
                    {services.slice(0, 4).map(service => (
                        <li class="text-gray-400 text-sm">{service.title}</li>
                    ))}
                </ul>
            </div>

            <!-- Contacts -->
            <div>
                <h3 class="text-base font-semibold mb-4 pb-2 border-b border-gray-700">{text.footCont}</h3>
                <div class="space-y-3">
                    <a href="tel:+37360680819" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors group">
                        <i class="ph-fill ph-phone text-orange-400 text-xl flex-shrink-0"></i>
                        <span class="text-lg font-bold">+373 60 680 819</span>
                    </a>
                    <div class="flex flex-wrap gap-2 pt-1">
                        <a href="https://wa.me/37360680819" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-1.5 bg-green-600/20 hover:bg-green-600/30 text-green-400 border border-green-600/30 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <i class="ph ph-whatsapp-logo text-base"></i> WhatsApp
                        </a>
                        <a href="viber://chat?number=%2B37360680819"
                           class="flex items-center gap-1.5 bg-purple-600/20 hover:bg-purple-600/30 text-purple-400 border border-purple-600/30 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <i class="ph ph-chat-circle text-base"></i> Viber
                        </a>
                        <a href="https://t.me/ProAcoperis" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-1.5 bg-sky-600/20 hover:bg-sky-600/30 text-sky-400 border border-sky-600/30 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <i class="ph ph-telegram-logo text-base"></i> Telegram
                        </a>
                        <a href="https://www.facebook.com/profile.php?id=61581585747077" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-1.5 bg-blue-600/20 hover:bg-blue-600/30 text-blue-400 border border-blue-600/30 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <i class="ph ph-facebook-logo text-base"></i> Facebook
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-3 text-gray-500 text-sm">
            <p>&copy; {currentYear} ProAcoperis.md. {text.footRights}</p>
            <p class="flex items-center gap-2">
                <i class="ph-fill ph-certificate text-orange-400"></i>
                {text.footMade}
            </p>
        </div>
    </div>
</footer>

<!-- Sticky messenger buttons -->
<div class="fixed bottom-8 right-3 sm:bottom-8 sm:right-4 z-50 flex flex-col gap-2 sm:gap-2.5">
    <a href="https://wa.me/37360680819" target="_blank" rel="noopener noreferrer"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-[#25D366] hover:bg-[#1ebe5d] rounded-full flex items-center justify-center shadow-lg shadow-green-500/40 hover:shadow-green-500/60 transition-all duration-200 hover:scale-110"
       aria-label="WhatsApp">
        <i class="ph ph-whatsapp-logo text-white text-lg sm:text-xl"></i>
    </a>
    <a href="viber://chat?number=%2B37360680819"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-[#7360F2] hover:bg-[#6250e0] rounded-full flex items-center justify-center shadow-lg shadow-purple-500/40 hover:shadow-purple-500/60 transition-all duration-200 hover:scale-110"
       aria-label="Viber">
        <i class="ph ph-chat-circle-dots text-white text-lg sm:text-xl"></i>
    </a>
    <a href="https://t.me/ProAcoperis" target="_blank" rel="noopener noreferrer"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-[#29A8EB] hover:bg-[#1a96d8] rounded-full flex items-center justify-center shadow-lg shadow-sky-500/40 hover:shadow-sky-500/60 transition-all duration-200 hover:scale-110"
       aria-label="Telegram">
        <i class="ph ph-telegram-logo text-white text-lg sm:text-xl"></i>
    </a>
    <a href="https://www.facebook.com/profile.php?id=61581585747077" target="_blank" rel="noopener noreferrer"
       class="group w-10 h-10 sm:w-11 sm:h-11 bg-[#1877F2] hover:bg-[#0d6ce0] rounded-full flex items-center justify-center shadow-lg shadow-blue-500/40 hover:shadow-blue-500/60 transition-all duration-200 hover:scale-110"
       aria-label="Facebook">
        <i class="ph ph-facebook-logo text-white text-lg sm:text-xl"></i>
    </a>
</div>

<!-- Phosphor icons: loaded after page renders, non-blocking -->
<script src="https://unpkg.com/@phosphor-icons/web@2.1.1" defer></script>

<script is:inline>
    const btn  = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');

    btn.addEventListener('click', () => {
        const isHidden = menu.classList.toggle('hidden');
        icon.className = isHidden ? 'ph ph-list text-3xl' : 'ph ph-x text-3xl';
    });

    // Scroll reveal
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
            }
        });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // Shrink header on scroll
    const header = document.getElementById('site-header');
    const headerInner = document.getElementById('header-inner');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
            headerInner.classList.replace('h-20', 'h-14');
        } else {
            headerInner.classList.replace('h-14', 'h-20');
        }
    }, { passive: true });
</script>
</body>
</html>
