---
import '../styles/global.css';
import { ui, getServicesData } from '../data/i18n.js';

const { lang, title, description = '' } = Astro.props;
const text = ui[lang];
const base = import.meta.env.BASE_URL;
const services = getServicesData(lang, base);
const currentYear = new Date().getFullYear(); // always trailing slash from astro.config base: '/Roof_proj/'
const rawPath = Astro.url.pathname.startsWith(base.slice(0, -1)) ? Astro.url.pathname.slice(base.length - 1) : Astro.url.pathname;
const currentPath = rawPath.replace(`/${lang}`, '') || '/';
const getLangLink = (targetLang) => targetLang === 'ro'
    ? `${base}${currentPath.slice(1)}`          // RO at root: /services, /
    : `${base}${targetLang}${currentPath}`;     // RU: /ru/services

// RO lives at root (/), RU at /ru/
const langPfx = lang === 'ro' ? '' : `${lang}/`;

// SEO: canonical + hreflang (only on production domain)
const siteOrigin = Astro.site ? Astro.site.origin : null;
const roPath     = currentPath === '/' ? '/' : currentPath;  // /services, /about …
const ruPath     = currentPath;                               // /services, /about …
const canonicalURL = siteOrigin
    ? (lang === 'ro' ? `${siteOrigin}${roPath}` : `${siteOrigin}/ru${ruPath}`)
    : null;
const hreflangRo = siteOrigin ? `${siteOrigin}${roPath}` : null;
const hreflangRu = siteOrigin ? `${siteOrigin}/ru${ruPath}` : null;

const navItems = [
    { id: 'home',      label: text.nav.home,      href: `${base}${langPfx}` },
    { id: 'services',  label: text.nav.services,  href: `${base}${langPfx}services` },
    { id: 'portfolio', label: text.nav.portfolio,  href: `${base}${langPfx}portfolio` },
    { id: 'about',     label: text.nav.about,      href: `${base}${langPfx}about` },
    { id: 'contacts',  label: text.nav.contacts,   href: `${base}${langPfx}contacts` }
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#111827">
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : 'ro_RO'} />
    <meta property="og:image" content={`${base}images/logo/LogoTranspBG.png`} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    {hreflangRu   && <link rel="alternate" hreflang="ru"        href={hreflangRu} />}
    {hreflangRo   && <link rel="alternate" hreflang="ro"        href={hreflangRo} />}
    {hreflangRu   && <link rel="alternate" hreflang="x-default" href={hreflangRu} />}
    <link rel="icon" type="image/png" href={`${base}images/logo/Favicon.png`} />

    <!-- Google Analytics (loads only after cookie consent) -->
    <script is:inline>
        window.GA_ID = 'G-XXXXXXXXXX'; // ← замени на свой GA4 Measurement ID
        function loadGA() {
            if (window._gaLoaded) return;
            window._gaLoaded = true;
            var s = document.createElement('script');
            s.src = 'https://www.googletagmanager.com/gtag/js?id=' + window.GA_ID;
            s.async = true;
            document.head.appendChild(s);
            window.dataLayer = window.dataLayer || [];
            function gtag(){ dataLayer.push(arguments); }
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', window.GA_ID, { anonymize_ip: true });
        }
        if (localStorage.getItem('cookieConsent') === 'yes') loadGA();
    </script>

    <!-- Google Fonts: non-blocking via preload swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap"></noscript>

    <!-- Performance: preconnect to external origins -->
    <link rel="preconnect" href="https://unpkg.com" crossorigin>
    <link rel="dns-prefetch" href="https://www.youtube.com">
    <link rel="dns-prefetch" href="https://img.youtube.com">

    <!-- Phosphor icons: defer so it doesn't block render -->
    <link rel="preload" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.css"></noscript>

    <!-- Page loader: critical inline styles to avoid FOUC -->
    <style>
        #page-loader {
            position: fixed; inset: 0; z-index: 10000;
            background: #111827;
            display: flex; align-items: center; justify-content: center;
            transition: opacity 0.5s ease;
        }
        #page-loader.loader-done { opacity: 0; pointer-events: none; }
        .pl-logo { font-family: 'Montserrat', system-ui, sans-serif; font-size: 1.9rem; font-weight: 900; letter-spacing: -0.5px; margin-bottom: 1.75rem; }
        .pl-pro  { color: #fff; }
        .pl-acop { color: #f97316; }
        .pl-dot  { color: #fbbf24; }
        .pl-bar  { width: 180px; height: 3px; background: rgba(255,255,255,0.15); border-radius: 99px; overflow: hidden; margin: 0 auto; }
        .pl-fill { height: 100%; width: 0; background: linear-gradient(to right, #f97316, #fbbf24); border-radius: 99px; animation: plFill 1.3s ease-out forwards; }
        @keyframes plFill { 0%{width:0} 65%{width:82%} 100%{width:100%} }
    </style>
</head>
<body class="font-sans bg-white text-gray-900 flex flex-col min-h-screen">

<!-- ═══ PAGE LOADER ═══ -->
<div id="page-loader" aria-hidden="true">
    <div style="text-align:center">
        <div class="pl-logo"><span class="pl-pro">Pro</span><span class="pl-acop">Acoperis</span><span class="pl-dot">.md</span></div>
        <div class="pl-bar"><div class="pl-fill"></div></div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════ HEADER -->
<header id="site-header" class="sticky top-0 z-50 bg-gray-900 backdrop-blur-md shadow-lg shadow-black/30">

    <!-- Accent bar — orange -->
    <div class="h-1 bg-gradient-to-r from-orange-600 via-orange-500 to-amber-400"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20" id="header-inner">

            <!-- Logo -->
            <a href={`${base}${lang}/`} class="flex items-center gap-2 xl:gap-3 flex-shrink-0 group">
                <img src={`${base}images/logo/LogoTranspBG.svg`} alt="ProAcoperis.md" class="h-9 xl:h-11 w-auto group-hover:scale-105 transition-transform duration-300" />
                <div>
                    <p class="text-base xl:text-2xl font-black leading-tight tracking-tight font-heading">
                        <span class="text-white">Pro</span><span class="text-orange-400">Acoperis</span><span class="text-amber-400">.md</span>
                    </p>
                    <p class="hidden xl:block text-xs text-gray-500 uppercase tracking-widest font-semibold">{text.brandExpert}</p>
                </div>
            </a>

            <!-- Desktop nav -->
            <nav class="hidden xl:flex items-center gap-0.5">
                {navItems.map(item => (
                    <a href={item.href} class="relative px-4 py-2 text-sm font-semibold text-gray-300 hover:text-white transition-colors rounded-lg hover:bg-white/10 group/nav">
                        {item.label}
                        <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-0 group-hover/nav:w-3/5 h-0.5 bg-orange-400 rounded-full transition-all duration-300"></span>
                    </a>
                ))}
            </nav>

            <!-- Desktop actions -->
            <div class="hidden xl:flex items-center gap-3">
                <div class="flex items-center bg-white/10 rounded-full p-1">
                    <a href={getLangLink('ru')} class={`w-10 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ru' ? 'bg-white/20 text-orange-400' : 'text-gray-400 hover:text-white'}`}>RU</a>
                    <a href={getLangLink('ro')} class={`w-10 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ro' ? 'bg-white/20 text-orange-400' : 'text-gray-400 hover:text-white'}`}>RO</a>
                </div>
                <a href="tel:+37360680819" class="flex items-center gap-2 bg-white/8 hover:bg-white/15 border border-white/15 text-white px-4 py-2 rounded-full font-medium transition-colors text-sm">
                    <i class="ph-fill ph-phone text-orange-400 text-base"></i>
                    +373 60 680 819
                </a>
                <a href={`${base}${lang}/contacts`} class="bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white px-5 py-2.5 rounded-full font-semibold transition-all whitespace-nowrap shadow-md shadow-orange-600/40 hover:shadow-orange-600/60 text-sm">
                    {text.freeEst}
                </a>
            </div>

            <!-- Mobile actions -->
            <div class="xl:hidden flex items-center gap-2">
                <div class="flex items-center bg-white/10 rounded-full p-1">
                    <a href={getLangLink('ru')} class={`w-9 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ru' ? 'bg-white/20 text-orange-400' : 'text-gray-400'}`}>RU</a>
                    <a href={getLangLink('ro')} class={`w-9 text-center py-1 rounded-full text-xs font-bold transition-colors ${lang === 'ro' ? 'bg-white/20 text-orange-400' : 'text-gray-400'}`}>RO</a>
                </div>
                <button id="mobile-menu-toggle" class="text-gray-400 hover:text-white focus:outline-none flex items-center justify-center w-10 h-10 rounded-xl hover:bg-white/10 transition-colors">
                    <i class="ph ph-list text-3xl" id="menu-icon"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden xl:hidden bg-gray-900 border-t border-white/10 absolute w-full left-0 shadow-2xl shadow-black/50">
        <div class="px-4 pt-3 pb-6 space-y-1">
            {navItems.map(item => (
                <a href={item.href} class="flex items-center px-4 py-3 rounded-xl text-base font-semibold text-gray-300 hover:bg-white/10 hover:text-white transition-colors">
                    {item.label}
                </a>
            ))}
            <div class="pt-3 border-t border-white/10 space-y-2.5 mt-2">
                <a href="tel:+37360680819" class="flex items-center justify-center gap-2 w-full bg-white/10 border border-white/20 text-white px-4 py-3 rounded-xl font-medium">
                    <i class="ph-fill ph-phone text-orange-400 text-xl"></i>
                    +373 60 680 819
                </a>
                <a href={`${base}${lang}/contacts`} class="flex items-center justify-center w-full bg-gradient-to-r from-orange-500 to-orange-600 text-white px-4 py-3.5 rounded-xl font-semibold shadow-md shadow-orange-600/30 transition-all">
                    {text.freeEst}
                </a>
            </div>
        </div>
    </div>
</header>

<main class="flex-grow">
    <slot />
</main>

<!-- ═══════════════════════════════════════════════════════ FOOTER -->
