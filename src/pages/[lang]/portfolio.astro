---
import Layout from '../../layouts/Layout.astro';
import { ui, languages, getPortfolioData, getGalleryData, getVideosData } from '../../data/i18n.js';

export function getStaticPaths() {
    return languages.map((lang) => ({ params: { lang } }));
}

const { lang }  = Astro.params;
const base = import.meta.env.BASE_URL;
const text      = ui[lang];
const portfolio = getPortfolioData(lang);
const gallery   = getGalleryData();
const videos    = getVideosData(lang);

const categories = lang === 'ru'
    ? ['Все', 'Мембрана ПВХ', 'Мембрана ТПО', 'Скатная кровля', 'Теплоизоляция', 'Еврорубероид']
    : ['Toate', 'Membrană PVC', 'Membrană TPO', 'Acoperiș în pantă', 'Termoizolație', 'Euroruberoid'];
---

<Layout lang={lang} title={text.nav.portfolio}>

<!-- ═══════════════════════════════════════════════ PAGE HERO -->
<section class="relative bg-gray-900 py-28 overflow-hidden">
    <img
        src="https://images.unsplash.com/photo-1587582423116-ec07293f0395?auto=format&fit=crop&q=80&w=1920"
        alt="" fetchpriority="high" decoding="async"
        class="absolute inset-0 w-full h-full object-cover opacity-30"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-gray-950/90 via-gray-900/70 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 text-blue-100 text-sm font-semibold px-4 py-2 rounded-full mb-6">
            <i class="ph-fill ph-buildings text-blue-400"></i>
            {text.portPageHeroBadge}
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-5 leading-tight">
            {text.portPageHeroTitle} <span class="text-blue-400">{text.portPageHeroTitle2}</span>
        </h1>
        <p class="text-gray-300 text-xl max-w-xl leading-relaxed mb-8">{text.portPageHeroDesc}</p>
        <a href={`${base}${lang}/contacts`} class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white px-7 py-4 rounded-2xl font-bold transition-all hover:-translate-y-0.5 shadow-lg shadow-blue-600/30">
            {text.btnCall} <i class="ph ph-arrow-right"></i>
        </a>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ PORTFOLIO GRID -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-600"></span>{text.portPageAllSub}
        </p>
        <h2 class="text-4xl font-extrabold text-gray-900 mb-10">{text.portPageAllTitle}</h2>

        <!-- Filter tabs -->
        <div class="flex flex-wrap gap-2 mb-10" id="filter-tabs">
            {categories.map((cat, idx) => (
                <button
                    class={`filter-btn px-5 py-2 rounded-full text-sm font-bold transition-all ${idx === 0 ? 'bg-blue-600 text-white shadow-md' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
                    data-filter={cat}
                    onclick="filterPortfolio(this)"
                >
                    {cat}
                </button>
            ))}
        </div>

        <!-- Portfolio items -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="portfolio-grid">
            {portfolio.map((item) => (
                <div class="portfolio-item group relative rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 h-[340px]"
                     data-category={item.category}>
                    <img src={item.image} alt={item.title} loading="lazy" decoding="async"
                        class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
                    <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-900/30 to-transparent opacity-80 group-hover:opacity-95 transition-opacity"></div>

                    <div class="absolute top-5 right-5">
                        <span class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-3 py-1 rounded-full border border-white/30">{item.year}</span>
                    </div>

                    <div class="absolute bottom-0 left-0 p-7 w-full translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                        <span class="inline-block px-3 py-1 bg-blue-600 text-white text-xs font-bold rounded-full mb-3">{item.category}</span>
                        <h3 class="text-xl font-bold text-white mb-1">{item.title}</h3>
                        <p class="text-gray-400 flex items-center gap-1 text-sm">
                            <i class="ph-fill ph-map-pin opacity-70"></i>{item.area}
                        </p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ FULL GALLERY -->
<section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-600"></span>{text.portPageGallerySub}
        </p>
        <h2 class="text-4xl font-extrabold text-gray-900 mb-12">{text.portPageGalleryTitle}</h2>

        <div class="columns-2 md:columns-3 lg:columns-4 gap-3 space-y-3">
            {gallery.map((item) => (
                <div class="break-inside-avoid group relative overflow-hidden rounded-2xl shadow hover:shadow-xl transition-shadow cursor-zoom-in"
                     onclick="openLightbox(this.querySelector('img').src, this.querySelector('img').alt)">
                    <img src={item.image} alt={item.label} loading="lazy" decoding="async"
                        class="w-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                    <div class="absolute inset-0 bg-gray-900/0 group-hover:bg-gray-900/40 transition-all duration-300">
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <div class="w-10 h-10 bg-white/90 rounded-full flex items-center justify-center shadow">
                                <i class="ph ph-magnifying-glass-plus text-gray-900 text-lg"></i>
                            </div>
                        </div>
                        <span class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 px-4 py-3 text-white text-xs font-semibold bg-gradient-to-t from-gray-900/80 to-transparent">
                            {item.label}
                        </span>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ VIDEOS -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-600"></span>
            {lang === 'ru' ? 'Видео о процессе' : 'Video despre proces'}
        </p>
        <h2 class="text-4xl font-extrabold text-gray-900 mb-12">
            {lang === 'ru' ? 'Как мы выполняем работы' : 'Cum executăm lucrările'}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {videos.map((video) => (
                <div class="rounded-2xl overflow-hidden shadow-md bg-gray-900">
                    <video
                        src={video.src}
                        poster={video.poster}
                        controls
                        preload="none"
                        class="w-full h-56 object-cover"
                    ></video>
                    <div class="p-4">
                        <span class="inline-block bg-blue-600 text-white text-xs font-bold px-2 py-0.5 rounded-full mb-2">{video.type}</span>
                        <h3 class="text-white font-bold text-sm leading-snug">{video.title}</h3>
                        <p class="text-gray-400 text-xs mt-1">{video.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ CTA -->
<section class="bg-gradient-to-br from-blue-600 to-blue-800 py-20 relative overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-5">{text.ctaTitle}</h2>
        <p class="text-blue-100 text-xl mb-10 leading-relaxed">{text.ctaDesc}</p>
        <a href={`${base}${lang}/contacts`} class="inline-block bg-white text-blue-600 px-10 py-5 rounded-2xl font-bold text-lg hover:bg-gray-50 transition-all hover:scale-105 shadow-2xl">
            {text.ctaBtn}
        </a>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ LIGHTBOX -->
<div id="lightbox" class="fixed inset-0 bg-black/90 z-[100] hidden items-center justify-center p-4" onclick="closeLightbox()">
    <button class="absolute top-5 right-5 text-white text-4xl hover:text-gray-300 transition-colors w-12 h-12 flex items-center justify-center">
        <i class="ph ph-x"></i>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] rounded-2xl shadow-2xl object-contain"/>
</div>

</Layout>

<script is:inline>
function filterPortfolio(btn) {
    const filter = btn.dataset.filter;
    const allLabel = document.querySelector('[data-filter]').dataset.filter === filter
        ? null
        : {ru: 'Все', ro: 'Toate'}[document.documentElement.lang];

    document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('bg-blue-600', 'text-white', 'shadow-md');
        b.classList.add('bg-gray-100', 'text-gray-600');
    });
    btn.classList.remove('bg-gray-100', 'text-gray-600');
    btn.classList.add('bg-blue-600', 'text-white', 'shadow-md');

    const isAll = (filter === 'Все' || filter === 'Toate');
    document.querySelectorAll('.portfolio-item').forEach(item => {
        if (isAll || item.dataset.category.includes(filter.replace('Membrană ', '').replace('Мембрана ', ''))) {
            item.style.display = '';
            item.style.opacity = '0';
            requestAnimationFrame(() => {
                item.style.transition = 'opacity 0.3s';
                item.style.opacity = '1';
            });
        } else {
            item.style.display = 'none';
        }
    });
}

function openLightbox(src, alt) {
    const lb = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img');
    img.src = src;
    img.alt = alt;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
}

function closeLightbox() {
    const lb = document.getElementById('lightbox');
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeLightbox();
});
</script>
