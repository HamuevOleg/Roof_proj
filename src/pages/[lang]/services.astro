---
import Layout from '../../layouts/Layout.astro';
import {
    ui, languages,
    getServicesData, getProcessData, getRoofSystemsData, getFAQData
} from '../../data/i18n.js';

export function getStaticPaths() {
    return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const base = import.meta.env.BASE_URL;
const text     = ui[lang];
const services = getServicesData(lang);
const process  = getProcessData(lang);
const systems  = getRoofSystemsData(lang);
const faq      = getFAQData(lang);
---

<Layout lang={lang} title={text.nav.services}>

<!-- ═══════════════════════════════════════════════ PAGE HERO -->
<section class="relative bg-gray-900 py-28 overflow-hidden">
    <img
        src="/images/portfolio/p07.jpg"
        alt="" fetchpriority="high" decoding="async"
        class="absolute inset-0 w-full h-full object-cover opacity-30"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-gray-950/90 via-gray-900/70 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 text-blue-100 text-sm font-semibold px-4 py-2 rounded-full mb-6">
            <i class="ph-fill ph-wrench text-blue-400"></i>
            {text.servPageHeroBadge}
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-5 leading-tight">
            {text.servPageHeroTitle} <span class="text-blue-400">{text.servPageHeroTitle2}</span>
        </h1>
        <p class="text-gray-300 text-xl max-w-xl leading-relaxed mb-8">{text.servPageHeroDesc}</p>
        <a href={`${base}${lang}/contacts`} class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white px-7 py-4 rounded-2xl font-bold transition-all hover:-translate-y-0.5 shadow-lg shadow-blue-600/30">
            {text.btnCall} <i class="ph ph-arrow-right"></i>
        </a>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ ALL SERVICES -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-600"></span>{text.servPageAllSub}
        </p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-14">{text.servPageAllTitle}</h2>

        <div class="space-y-8">
            {services.map((service, idx) => (
                <div class={`group flex flex-col ${idx % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-0 rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 bg-gray-50`}>
                    <!-- Image -->
                    <div class="lg:w-2/5 relative overflow-hidden h-64 lg:h-auto min-h-[260px]">
                        <img
                            src={service.image} alt={service.title}
                            loading="lazy" decoding="async"
                            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                        />
                        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-gray-900/40 lg:hidden"></div>
                    </div>
                    <!-- Content -->
                    <div class="lg:w-3/5 p-8 md:p-10 flex flex-col justify-center">
                        <div class="flex items-center gap-3 mb-5">
                            <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-md flex-shrink-0">
                                <i class={`${service.icon} text-2xl`}></i>
                            </div>
                            <div>
                                <h3 class="text-2xl font-extrabold text-gray-900">{service.title}</h3>
                                <span class="text-sm font-bold text-blue-600">{service.price}</span>
                            </div>
                        </div>
                        <p class="text-gray-600 leading-relaxed mb-6">{service.desc}</p>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 mb-7">
                            {service.benefits.map((b) => (
                                <li class="flex items-center gap-2 text-sm text-gray-700 font-medium">
                                    <i class="ph-fill ph-check-circle text-blue-600 text-lg flex-shrink-0"></i>
                                    {b}
                                </li>
                            ))}
                        </ul>
                        <a href={`${base}${lang}/contacts`} class="inline-flex items-center gap-2 text-blue-600 font-bold hover:text-blue-800 transition-colors self-start text-sm">
                            {text.btnCall} <i class="ph ph-arrow-right"></i>
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ ROOF SYSTEMS TABS -->
<section class="py-24 bg-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-400 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-400"></span>{text.servPageSystemsSub}
        </p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-10">
            {text.servPageSystemsTitle1} <span class="text-blue-400">{text.servPageSystemsTitle2}</span>
        </h2>

        <!-- Tab buttons -->
        <div class="flex flex-wrap gap-3 mb-8" id="systems-tabs">
            {systems.map((sys, idx) => (
                <button
                    data-tab={sys.id}
                    onclick="switchSystem(this)"
                    class={`systems-tab px-5 py-2.5 rounded-full font-bold text-sm transition-all duration-200 ${idx === 0 ? 'bg-blue-600 text-white shadow-lg' : 'bg-white/10 text-gray-300 hover:bg-white/20'}`}
                >
                    {sys.tag}
                </button>
            ))}
        </div>

        <!-- Tab panels -->
        {systems.map((sys, idx) => (
            <div id={`system-panel-${sys.id}`} class={`systems-panel ${idx !== 0 ? 'hidden' : ''}`}>
                <div class="bg-white/5 border border-white/10 rounded-3xl p-8 md:p-10">
                    <!-- Client question -->
                    <div class="flex items-start gap-4 mb-8 bg-white/5 rounded-2xl p-5 border border-white/10">
                        <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0 mt-0.5">
                            <i class="ph-fill ph-user text-white text-lg"></i>
                        </div>
                        <div>
                            <p class="text-blue-400 text-xs font-bold uppercase tracking-wider mb-1">{text.servPageSystemsClient}</p>
                            <p class="text-white text-lg font-medium italic">«{sys.clientAsk}»</p>
                        </div>
                    </div>

                    <div class="flex flex-col lg:flex-row gap-10">
                        <div class="lg:w-1/3">
                            <div class={`inline-flex items-center gap-2 ${sys.colorClass} text-white px-4 py-2 rounded-full text-sm font-bold mb-5`}>
                                <i class={`${sys.icon} text-lg`}></i>
                                {sys.tag}
                            </div>
                            <h3 class="text-2xl md:text-3xl font-extrabold text-white mb-4">{sys.title}</h3>
                            <p class="text-gray-400 leading-relaxed mb-5">{sys.desc}</p>
                            <p class="text-blue-400 text-sm font-bold uppercase tracking-wider">{text.servPageSystemsWeOffer}</p>
                        </div>
                        <div class="lg:w-2/3">
                            <ol class="space-y-3">
                                {sys.steps.map((step, i) => (
                                    <li class="flex gap-4 items-start group/step">
                                        <span class={`flex-shrink-0 w-8 h-8 rounded-full ${sys.colorClass} flex items-center justify-center text-white text-sm font-bold`}>{i + 1}</span>
                                        <p class="text-gray-300 leading-relaxed pt-1 group-hover/step:text-white transition-colors">{step}</p>
                                    </li>
                                ))}
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

<!-- ═══════════════════════════════════════════════ PROCESS -->
<section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-600"></span>{text.servPageProcessSub}
        </p>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4">
            <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight">
                {text.servPageProcessTitle1} <span class="text-blue-600">{text.servPageProcessTitle2}</span>
            </h2>
            <div class="md:text-right max-w-xs">
                <p class="text-gray-400 text-sm italic">{text.servPageProcessAsk}</p>
                <p class="text-gray-700 font-semibold text-sm">{text.servPageProcessAskText}</p>
            </div>
        </div>

        <!-- Timeline grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {process.map((item) => (
                <div class="group bg-white rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex gap-5 items-start">
                    <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue-600 text-white flex items-center justify-center font-extrabold text-lg shadow-md shadow-blue-600/30">{item.step}</div>
                    <div>
                        <div class="text-blue-600 mb-2"><i class={`${item.icon} text-2xl`}></i></div>
                        <h3 class="text-base font-bold text-gray-900 mb-1.5">{item.title}</h3>
                        <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ FAQ -->
<section class="py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-600"></span>{text.servPageFaqSub}
        </p>
        <h2 class="text-4xl font-extrabold text-gray-900 mb-12">{text.servPageFaqTitle}</h2>

        <div class="space-y-4" id="faq-list">
            {faq.map((item, idx) => (
                <div class="faq-item border border-gray-200 rounded-2xl overflow-hidden">
                    <button
                        class="faq-btn w-full text-left px-7 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors"
                        onclick="toggleFaq(this)"
                    >
                        <span class="font-semibold text-gray-900 text-base">{item.q}</span>
                        <i class="ph ph-caret-down text-blue-600 text-xl flex-shrink-0 transition-transform duration-300"></i>
                    </button>
                    <div class="faq-body hidden px-7 pb-6">
                        <p class="text-gray-600 leading-relaxed">{item.a}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ CTA -->
<section class="bg-gradient-to-br from-blue-600 to-blue-800 py-20 relative overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-5">{text.ctaTitle}</h2>
        <p class="text-blue-100 text-xl mb-10 leading-relaxed">{text.ctaDesc}</p>
        <a href={`${base}${lang}/contacts`} class="inline-block bg-white text-blue-600 px-10 py-5 rounded-2xl font-bold text-lg hover:bg-gray-50 transition-all hover:scale-105 shadow-2xl">
            {text.ctaBtn}
        </a>
    </div>
</section>

</Layout>

<script is:inline>
function switchSystem(btn) {
    const id = btn.dataset.tab;
    document.querySelectorAll('.systems-panel').forEach(p => p.classList.add('hidden'));
    document.querySelectorAll('.systems-tab').forEach(b => {
        b.classList.remove('bg-blue-600', 'text-white', 'shadow-lg');
        b.classList.add('bg-white/10', 'text-gray-300');
    });
    document.getElementById('system-panel-' + id)?.classList.remove('hidden');
    btn.classList.remove('bg-white/10', 'text-gray-300');
    btn.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
}

function toggleFaq(btn) {
    const body  = btn.nextElementSibling;
    const icon  = btn.querySelector('i');
    const open  = !body.classList.contains('hidden');
    // Close all
    document.querySelectorAll('.faq-body').forEach(b => b.classList.add('hidden'));
    document.querySelectorAll('.faq-btn i').forEach(i => i.style.transform = '');
    if (!open) {
        body.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
    }
}
</script>
