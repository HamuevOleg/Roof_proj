---
import Layout from '../../layouts/Layout.astro';
import { ui, languages, getStatsData, getFeaturesData, getAboutValuesData } from '../../data/i18n.js';

export function getStaticPaths() {
    return languages.map((lang) => ({ params: { lang } }));
}

const { lang }  = Astro.params;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const text      = ui[lang];
const stats     = getStatsData(lang);
const features  = getFeaturesData(lang);
const values    = getAboutValuesData(lang);
---

<Layout lang={lang} title={text.nav.about}>

<!-- ═══════════════════════════════════════════════ PAGE HERO -->
<section class="relative bg-gray-900 py-28 overflow-hidden">
    <img
        src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=1920"
        alt="" fetchpriority="high" decoding="async"
        class="absolute inset-0 w-full h-full object-cover opacity-25"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-gray-950/90 via-gray-900/70 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 text-blue-100 text-sm font-semibold px-4 py-2 rounded-full mb-6">
            <i class="ph-fill ph-medal text-yellow-400"></i>
            {text.aboutPageHeroBadge}
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-5 leading-tight">
            {text.aboutPageHeroTitle} <span class="text-blue-400">{text.aboutPageHeroTitle2}</span>
        </h1>
        <p class="text-gray-300 text-xl max-w-xl leading-relaxed">{text.aboutPageHeroDesc}</p>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ STORY -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-16 items-start">
            <!-- Text -->
            <div class="lg:w-1/2">
                <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
                    <span class="w-8 h-0.5 bg-blue-600"></span>{text.aboutStorySub}
                </p>
                <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-8 leading-tight">{text.aboutStoryTitle}</h2>
                <div class="space-y-5 text-gray-600 leading-relaxed text-lg">
                    <p>{text.aboutStoryText1}</p>
                    <p>{text.aboutStoryText2}</p>
                    <p>{text.aboutStoryText3}</p>
                </div>

                <!-- Partner badge -->
                <div class="mt-10 inline-flex items-center gap-4 bg-blue-50 border border-blue-100 rounded-2xl px-6 py-4">
                    <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center text-white flex-shrink-0">
                        <i class="ph ph-certificate text-2xl"></i>
                    </div>
                    <div>
                        <p class="font-bold text-gray-900 text-sm">{lang === 'ru' ? 'Официальный партнёр' : 'Partener oficial'}</p>
                        <p class="text-gray-500 text-sm">{lang === 'ru' ? 'Технониколь — сертификат действителен' : 'Technonicol — certificat valabil'}</p>
                    </div>
                </div>
            </div>

            <!-- Images collage -->
            <div class="lg:w-1/2 grid grid-cols-2 gap-4">
                <div class="rounded-3xl overflow-hidden h-56 row-span-2 shadow-xl">
                    <img src="https://images.unsplash.com/photo-1504307651254-35680f356f12?auto=format&fit=crop&q=80&w=600"
                        alt="" loading="lazy" decoding="async" class="w-full h-full object-cover"/>
                </div>
                <div class="rounded-3xl overflow-hidden h-[108px] shadow-xl">
                    <img src="https://images.unsplash.com/photo-1621905252507-b35492cc74b4?auto=format&fit=crop&q=80&w=600"
                        alt="" loading="lazy" decoding="async" class="w-full h-full object-cover"/>
                </div>
                <div class="rounded-3xl overflow-hidden h-[108px] shadow-xl">
                    <img src="https://images.unsplash.com/photo-1541888086225-ee80c2f829ec?auto=format&fit=crop&q=80&w=600"
                        alt="" loading="lazy" decoding="async" class="w-full h-full object-cover"/>
                </div>
                <div class="col-span-2 rounded-3xl overflow-hidden h-48 shadow-xl">
                    <img src="https://images.unsplash.com/photo-1587582423116-ec07293f0395?auto=format&fit=crop&q=80&w=1000"
                        alt="" loading="lazy" decoding="async" class="w-full h-full object-cover"/>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ STATS -->
<section class="py-20 bg-blue-600">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-blue-500 rounded-3xl overflow-hidden">
            {stats.map((stat) => (
                <div class="bg-blue-600 px-8 py-10 text-center">
                    <div class="text-4xl md:text-5xl font-extrabold text-white mb-2">{stat.number}</div>
                    <div class="text-blue-200 text-sm font-semibold uppercase tracking-wider">{stat.label}</div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ VALUES -->
<section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-600"></span>{text.aboutValuesSub}
        </p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-14">{text.aboutValuesTitle}</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {values.map((v, idx) => (
                <div class="group bg-white rounded-3xl p-8 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex gap-6 items-start">
                    <div class="w-14 h-14 rounded-2xl bg-blue-600 flex items-center justify-center flex-shrink-0 text-white group-hover:scale-110 transition-transform shadow-md shadow-blue-600/30">
                        <i class={`${v.icon} text-2xl`}></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors">{v.title}</h3>
                        <p class="text-gray-500 leading-relaxed">{v.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ WHY US (features) -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-600"></span>
            {lang === 'ru' ? 'Гарантии' : 'Garanții'}
        </p>
        <h2 class="text-4xl font-extrabold text-gray-900 mb-12">
            {lang === 'ru' ? 'Три причины выбрать ProRoof' : 'Trei motive să alegeți ProRoof'}
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {features.map((feature, idx) => (
                <div class="group relative bg-gray-50 hover:bg-blue-600 p-9 rounded-3xl border border-gray-100 transition-all duration-300 overflow-hidden text-center">
                    <div class="w-16 h-16 bg-white group-hover:bg-white/20 rounded-2xl shadow flex items-center justify-center mx-auto mb-6 transition-colors text-orange-500 group-hover:text-white">
                        <i class={`${feature.icon} text-4xl`}></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 group-hover:text-white mb-3 transition-colors">{feature.title}</h3>
                    <p class="text-gray-500 group-hover:text-blue-100 leading-relaxed transition-colors">{feature.desc}</p>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ TIMELINE -->
<section class="py-24 bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-blue-400 uppercase mb-3 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-blue-400"></span>
            {lang === 'ru' ? 'Хронология' : 'Cronologie'}
        </p>
        <h2 class="text-4xl font-extrabold text-white mb-12">
            {lang === 'ru' ? 'Вехи компании' : 'Etapele companiei'}
        </h2>

        <div class="relative">
            <div class="absolute left-6 top-0 bottom-0 w-px bg-white/10"></div>
            <div class="space-y-8">
                {[
                    { year: '2012', ru: 'Основание компании. Первые объекты в Кишинёве.', ro: 'Fondarea companiei. Primele obiecte în Chișinău.' },
                    { year: '2015', ru: 'Получение статуса официального партнёра Технониколь.', ro: 'Obținerea statutului de partener oficial Technonicol.' },
                    { year: '2018', ru: 'Расширение команды до 30+ специалистов. Первый объект более 5 000 м².', ro: 'Extinderea echipei la 30+ specialiști. Primul obiect de peste 5.000 m².' },
                    { year: '2021', ru: 'Запуск направления скатных кровель. 300+ сданных объектов.', ro: 'Lansarea direcției acoperișuri în pantă. 300+ obiecte predate.' },
                    { year: '2024', ru: '500+ объектов. 50+ специалистов в штате. Гарантия до 15 лет.', ro: '500+ obiecte. 50+ specialiști în personal. Garanție de până la 15 ani.' },
                ].map((item) => (
                    <div class="flex gap-6 items-start pl-4">
                        <div class="relative flex-shrink-0">
                            <div class="w-5 h-5 bg-blue-600 rounded-full border-4 border-gray-900 -ml-2.5 mt-1 shadow-lg shadow-blue-600/50"></div>
                        </div>
                        <div class="bg-white/5 rounded-2xl px-6 py-5 flex-grow border border-white/10 hover:border-blue-500/40 transition-colors">
                            <span class="text-blue-400 font-extrabold text-lg block mb-1">{item.year}</span>
                            <p class="text-gray-300 leading-relaxed">{lang === 'ru' ? item.ru : item.ro}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ CTA -->
<section class="bg-gradient-to-br from-blue-600 to-blue-800 py-20 relative overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-5">{text.ctaTitle}</h2>
        <p class="text-blue-100 text-xl mb-10 leading-relaxed">{text.ctaDesc}</p>
        <a href={`${base}${lang}/contacts`} class="inline-block bg-white text-blue-600 px-10 py-5 rounded-2xl font-bold text-lg hover:bg-gray-50 transition-all hover:scale-105 shadow-2xl">
            {text.ctaBtn}
        </a>
    </div>
</section>

</Layout>
