---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getImg } from '../../data/imageMap.js';
import {
    ui, languages,
    getServicesData, getProcessData, getRoofSystemsData, getFAQData
} from '../../data/i18n.js';

export function getStaticPaths() {
    return [
        { params: { lang: undefined } },
        { params: { lang: 'ru' } },
        { params: { lang: 'ro' } },
    ];
}

const rawLang = Astro.params.lang;
const base = import.meta.env.BASE_URL;
if (rawLang === 'ro') return Astro.redirect(`${base}services`, 301);
const lang = rawLang ?? 'ro';
const pfx = lang === 'ro' ? '' : `${lang}/`;
const text     = ui[lang];
const services = getServicesData(lang, base);

// ── Work-in-progress masonry images (src/assets/images/works/)
const works = [
    { imageKey: 'works/photo_2026-03-07_18-15-19.jpg',          label: lang === 'ru' ? 'МЖД / Новострой · Праймирование плоской кровли · Телецентр, Кишинёв · ~400 м² · 2025'          : 'Bloc locativ / Construcție nouă · Amorsare acoperiș plat · Telecentru, Chișinău · ~400 m² · 2025',         live: true },
    { imageKey: 'works/photo_2026-03-07_18-01-44 (2).jpg',       label: lang === 'ru' ? 'Частный дом / Коттедж · Утепление плоской кровли XPS · г. Кодру · ~120 м² · 2026'               : 'Casă privată / Casă de vacanță · Termoizolație acoperiș plat XPS · or. Codru · ~120 m² · 2026',           live: true },
    { imageKey: 'works/photo_2026-03-07_18-01-48 (3).jpg',       label: lang === 'ru' ? 'Частный дом с мансардой · Стропила и гидробарьер изнутри · ком. Гратиешты · ~150 м² · 2025'     : 'Casă cu mansardă · Căpriori și hidrobarieră interior · com. Grătiești · ~150 m² · 2025',                  live: true },
    { imageKey: 'works/photo_2026-03-07_18-01-48.jpg',            label: lang === 'ru' ? 'Частный дом с мансардой · Подкровельное пространство и мансардные окна · ком. Гратиешты · ~150 м² · 2025' : 'Casă cu mansardă · Spațiu subteran și ferestre mansardă · com. Grătiești · ~150 m² · 2025', live: true },
    { imageKey: 'works/photo_2026-03-07_18-08-04.jpg',            label: lang === 'ru' ? 'Жилой комплекс · Гибкая черепица на купол · Чеканы, Кишинёв · ~80 м² · 2024'                    : 'Complex locativ · Șindrilă flexibilă pe cupolă · Ciocana, Chișinău · ~80 m² · 2024',                    live: true },
    { imageKey: 'works/photo_2026-03-07_18-08-05 (2).jpg',        label: lang === 'ru' ? 'Частный дом · Праймирование под наплавляемые материалы ТехноНИКОЛЬ · с. Колоница · ~90 м² · 2025' : 'Casă privată · Amorsare înainte de membrane bituminoase TechnoNICOL · s. Colonița · ~90 m² · 2025',     live: true },
    { imageKey: 'works/photo_2026-03-07_18-15-18 (3).jpg',        label: lang === 'ru' ? 'Частный дом / Пристройка · Монтаж XPS поверх гидроизоляции · г. Сынжера · ~60 м² · 2026'         : 'Casă privată / Extensie · Montaj XPS peste hidroizolație · or. Sângera · ~60 m² · 2026',                  live: true },
    { imageKey: 'works/photo_2026-03-07_18-15-18.jpg',            label: lang === 'ru' ? 'Частный дом / Пристройка · Утепление примыканий и парапетов XPS · г. Сынжера · ~60 м² · 2026'    : 'Casă privată / Extensie · Termoizolație racorduri și parapete XPS · or. Sângera · ~60 m² · 2026',        live: true },
];
const process  = getProcessData(lang);
const systems  = getRoofSystemsData(lang);
const faq      = getFAQData(lang);
---

<Layout lang={lang} title={text.seo.services.title} description={text.seo.services.desc}>

<!-- ═══════════════════════════════════════════════ PAGE HERO -->
<section class="relative bg-gray-900 py-28 overflow-hidden">
    <Image
        src={getImg('portfolio/p07.jpg')}
        alt=""
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover opacity-30"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-gray-950/90 via-gray-900/70 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 text-orange-100 text-sm font-semibold px-4 py-2 rounded-full mb-6">
            <i class="ph-fill ph-wrench text-orange-400"></i>
            {text.servPageHeroBadge}
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold font-heading text-white mb-5 leading-tight">
            {text.servPageHeroTitle} <span class="text-orange-400">{text.servPageHeroTitle2}</span>
        </h1>
        <p class="text-gray-300 text-xl max-w-xl leading-relaxed mb-8">{text.servPageHeroDesc}</p>
        <a href={`${base}${pfx}contacts`} class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white px-7 py-4 rounded-2xl font-bold transition-all hover:-translate-y-0.5 shadow-lg shadow-orange-500/30 btn-pulse">
            {text.btnCall} <i class="ph ph-arrow-right"></i>
        </a>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ ALL SERVICES -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-orange-500 uppercase mb-3 flex items-center gap-3 reveal">
            <span class="w-8 h-0.5 bg-orange-500"></span>{text.servPageAllSub}
        </p>
        <h2 class="text-4xl md:text-5xl font-extrabold font-heading text-gray-900 mb-14 reveal">{text.servPageAllTitle}</h2>

        <div class="space-y-8">
            {services.map((service, idx) => (
                <div class={`reveal group flex flex-col ${idx % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-0 rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 bg-gray-50`}>
                    <!-- Image -->
                    <div class="lg:w-2/5 relative overflow-hidden h-64 lg:h-auto min-h-[260px]">
                        <Image
                            src={getImg(service.image)} alt={service.title}
                            loading="lazy" decoding="async"
                            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                        />
                        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-gray-900/40 lg:hidden"></div>
                    </div>
                    <!-- Content -->
                    <div class="lg:w-3/5 p-8 md:p-10 flex flex-col justify-center">
                        <div class="flex items-center gap-3 mb-5">
                            <div class="w-12 h-12 bg-orange-500 rounded-2xl flex items-center justify-center text-white shadow-md flex-shrink-0">
                                <i class={`${service.icon} text-2xl`}></i>
                            </div>
                            <div>
                                <h3 class="text-2xl font-extrabold text-gray-900">{service.title}</h3>
                                <span class="text-sm font-bold text-orange-500">{service.price}</span>
                            </div>
                        </div>
                        <p class="text-gray-600 leading-relaxed mb-6">{service.desc}</p>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 mb-7">
                            {service.benefits.map((b) => (
                                <li class="flex items-center gap-2 text-sm text-gray-700 font-medium">
                                    <i class="ph-fill ph-check-circle text-orange-500 text-lg flex-shrink-0"></i>
                                    {b}
                                </li>
                            ))}
                        </ul>
                        <a href={`${base}${pfx}contacts`} class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white px-5 py-2.5 rounded-xl font-bold transition-all self-start text-sm shadow-md shadow-orange-500/25">
                            {text.btnCall} <i class="ph ph-arrow-right"></i>
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ ROOF SYSTEMS -->
<section class="py-24 bg-[#1A1C20] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-orange-400 uppercase mb-3 flex items-center gap-3 reveal">
            <span class="w-8 h-0.5 bg-orange-400"></span>{text.servPageSystemsSub}
        </p>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-14 reveal">
            <h2 class="text-4xl md:text-5xl font-extrabold font-heading text-white leading-tight">
                {text.servPageSystemsTitle1} <span class="text-orange-400">{text.servPageSystemsTitle2}</span>
            </h2>
            <p class="text-gray-500 text-sm max-w-xs md:text-right leading-relaxed">
                {lang === 'ru' ? 'Подберём систему под ваш объект — выезд и оценка бесплатно' : 'Selectăm sistemul pentru obiectul dvs. — deplasare și evaluare gratuite'}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {systems.map((sys, idx) => (
                <div class={`reveal reveal-delay-${Math.min(idx + 1, 4)} relative flex flex-col rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-0.5
                    ${sys.badge
                        ? 'border-2 border-orange-500 bg-[#22252A] shadow-[0_10px_40px_rgba(0,0,0,0.5)]'
                        : 'border border-[#33373E] bg-[#22252A] hover:border-white/20 shadow-[0_10px_30px_rgba(0,0,0,0.4)]'
                    }`}>

                    <!-- Top line: 4px orange only for badge card -->
                    {sys.badge
                        ? <div class="h-1 bg-orange-500 flex-shrink-0"></div>
                        : <div class="h-px bg-[#33373E] flex-shrink-0"></div>
                    }

                    <!-- Badge -->
                    {sys.badge && (
                        <div class="absolute top-4 right-4 z-10">
                            <span class="inline-flex items-center gap-1 bg-orange-500 text-white text-[11px] font-bold px-3 py-1 rounded-full shadow-lg">
                                {sys.badge}
                            </span>
                        </div>
                    )}

                    <!-- Header -->
                    <div class="px-7 pt-6 pb-5 flex items-center gap-4 border-b border-[#33373E]">
                        <div class={`w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 ${sys.badge ? 'bg-orange-500/15' : 'bg-white/5'}`}>
                            <i class={`${sys.icon} text-xl ${sys.badge ? 'text-orange-400' : 'text-gray-400'}`}></i>
                        </div>
                        <div>
                            <span class="text-gray-600 text-xs font-medium block mb-0.5 tracking-wide">{sys.tag}</span>
                            <h3 class="text-white font-bold text-lg leading-tight">{sys.title}</h3>
                        </div>
                    </div>

                    <!-- Body -->
                    <div class="flex flex-col flex-grow px-7 py-6 gap-5">

                        <!-- Price -->
                        <div>
                            <div class="flex items-baseline gap-1.5 mb-1.5">
                                <span class="text-gray-600 text-sm">{lang === 'ru' ? 'от' : 'de la'}</span>
                                <span class="text-5xl font-black text-white leading-none tracking-tight">{sys.priceNum}</span>
                                <span class="text-gray-600 text-sm self-end mb-1">{sys.priceUnit}</span>
                            </div>
                            <p class="text-gray-300 text-sm leading-relaxed">{sys.tagline}</p>
                        </div>

                        <!-- Что входит -->
                        <div class="border-t border-[#33373E] pt-5">
                            <p class="text-gray-600 text-[11px] font-bold uppercase tracking-widest mb-3">
                                {lang === 'ru' ? 'Что входит' : 'Ce include'}
                            </p>
                            <ul class="space-y-2">
                                {sys.includes.map((item) => (
                                    <li class="flex items-start gap-2.5 text-sm text-gray-300">
                                        <span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0 mt-2"></span>
                                        {item}
                                    </li>
                                ))}
                            </ul>
                        </div>

                        <!-- Вы получаете -->
                        <div class="border-t border-[#33373E] pt-5 flex-grow">
                            <p class="text-gray-600 text-[11px] font-bold uppercase tracking-widest mb-3">
                                {lang === 'ru' ? 'Вы получаете' : 'Obțineți'}
                            </p>
                            <ul class="space-y-2.5">
                                {sys.results.map((r) => (
                                    <li class="flex items-start gap-2.5">
                                        <i class="ph-fill ph-check-circle text-orange-500 text-base flex-shrink-0 mt-0.5"></i>
                                        <span class="text-gray-200 text-sm leading-snug">{r}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>

                        <!-- CTA -->
                        {sys.badge
                            ? <a href={`${base}${pfx}contacts`}
                                 class="flex items-center justify-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold text-sm rounded-xl px-5 py-3.5 transition-colors shadow-lg shadow-orange-500/20">
                                <i class="ph-fill ph-ruler text-base"></i>
                                {lang === 'ru' ? 'Узнать цену для моего объекта' : 'Aflați prețul pentru obiectul meu'}
                              </a>
                            : <a href={`${base}${pfx}contacts`}
                                 class="flex items-center justify-center gap-2 border border-orange-500/50 text-orange-400 hover:bg-orange-500 hover:border-orange-500 hover:text-white font-bold text-sm rounded-xl px-5 py-3.5 transition-all duration-200">
                                <i class="ph-fill ph-ruler text-base"></i>
                                {lang === 'ru' ? 'Узнать цену для моего объекта' : 'Aflați prețul pentru obiectul meu'}
                              </a>
                        }
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ WORKS MASONRY -->
<section class="py-24 bg-[#121212]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 reveal">
            <div>
                <p class="text-orange-500 text-xs font-bold uppercase tracking-widest mb-3 flex items-center gap-3">
                    <span class="w-8 h-0.5 bg-orange-500"></span>
                    {lang === 'ru' ? 'Примеры работ' : 'Exemple de lucrări'}
                </p>
                <h2 class="text-4xl md:text-5xl font-extrabold font-heading text-white leading-tight">
                    {lang === 'ru' ? 'В работе прямо сейчас' : 'Lucrări în desfășurare'}
                </h2>
            </div>
            <a href={`${base}${pfx}portfolio`}
               class="group inline-flex items-center gap-2 text-gray-400 hover:text-white border border-[#33373E] hover:border-white/30 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 whitespace-nowrap flex-shrink-0">
                {lang === 'ru' ? 'Все работы' : 'Toate lucrările'}
                <i class="ph ph-arrow-right group-hover:translate-x-0.5 transition-transform"></i>
            </a>
        </div>

        <!-- Masonry grid — CSS columns -->
        <div class="columns-1 sm:columns-2 lg:columns-3 gap-3">
            {works.map((item) => (
                <div class="break-inside-avoid mb-3 group relative overflow-hidden rounded-xl cursor-zoom-in"
                     onclick={`openWorksLightbox('${getImg(item.imageKey).src}', '${item.label}')`}>

                    <!-- Image — natural height = masonry effect -->
                    <Image
                        src={getImg(item.imageKey)} alt={item.label}
                        loading="lazy" decoding="async"
                        class="w-full h-auto block transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                    />

                    <!-- Dark overlay — slides up on hover -->
                    <div class="absolute inset-0 bg-gradient-to-t from-gray-950/90 via-gray-950/20 to-transparent translate-y-full group-hover:translate-y-0 transition-transform duration-400 ease-out flex flex-col justify-end p-4">
                        <p class="text-white font-bold text-sm leading-snug">{item.label}</p>
                    </div>

                    <!-- Zoom icon — appears on hover -->
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
                        <div class="w-10 h-10 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full flex items-center justify-center">
                            <i class="ph ph-magnifying-glass-plus text-white text-lg"></i>
                        </div>
                    </div>

                    <!-- "В работе" badge -->
                    {item.live && (
                        <div class="absolute top-3 left-3">
                            <span class="inline-flex items-center gap-1.5 bg-[#121212]/80 backdrop-blur-sm border border-orange-500/40 text-orange-400 text-[10px] font-bold px-2.5 py-1 rounded-full">
                                <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
                                {lang === 'ru' ? 'В работе' : 'În lucru'}
                            </span>
                        </div>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>

<!-- Lightbox for works -->
<div id="works-lightbox" class="fixed inset-0 bg-black/92 z-[200] hidden items-center justify-center p-4 flex-col gap-4"
     onclick="closeWorksLightbox()">
    <button class="absolute top-5 right-5 text-white/60 hover:text-white w-10 h-10 flex items-center justify-center rounded-xl hover:bg-white/10 transition-colors">
        <i class="ph ph-x text-2xl"></i>
    </button>
    <img id="works-lb-img" src="" alt="" class="max-w-full max-h-[80vh] rounded-xl object-contain shadow-2xl"/>
    <div class="text-center">
        <p id="works-lb-label" class="text-white font-bold text-base"></p>
        <p id="works-lb-sub" class="text-gray-500 text-sm mt-0.5"></p>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ PROCESS -->
<section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-orange-500 uppercase mb-3 flex items-center gap-3 reveal">
            <span class="w-8 h-0.5 bg-orange-500"></span>{text.servPageProcessSub}
        </p>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4">
            <h2 class="text-4xl md:text-5xl font-extrabold font-heading text-gray-900 leading-tight reveal">
                {text.servPageProcessTitle1} <span class="text-orange-500">{text.servPageProcessTitle2}</span>
            </h2>
            <div class="md:text-right max-w-xs reveal">
                <p class="text-gray-400 text-sm italic">{text.servPageProcessAsk}</p>
                <p class="text-gray-700 font-semibold text-sm">{text.servPageProcessAskText}</p>
            </div>
        </div>

        <!-- Timeline grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {process.map((item, idx) => (
                <div class={`reveal reveal-delay-${Math.min(idx + 1, 4)} group bg-white rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex gap-5 items-start`}>
                    <div class="flex-shrink-0 w-12 h-12 rounded-full bg-orange-500 text-white flex items-center justify-center font-extrabold text-lg shadow-md shadow-orange-500/30">{item.step}</div>
                    <div>
                        <div class="text-orange-500 mb-2"><i class={`${item.icon} text-2xl`}></i></div>
                        <h3 class="text-base font-bold text-gray-900 mb-1.5">{item.title}</h3>
                        <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ FAQ -->
<section class="py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold tracking-widest text-orange-500 uppercase mb-3 flex items-center gap-3 reveal">
            <span class="w-8 h-0.5 bg-orange-500"></span>{text.servPageFaqSub}
        </p>
        <h2 class="text-4xl font-extrabold font-heading text-gray-900 mb-12 reveal">{text.servPageFaqTitle}</h2>

        <div class="space-y-4 reveal" id="faq-list">
            {faq.map((item, idx) => (
                <div class="faq-item border border-gray-200 rounded-2xl overflow-hidden">
                    <button
                        class="faq-btn w-full text-left px-7 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors"
                        onclick="toggleFaq(this)"
                    >
                        <span class="font-semibold text-gray-900 text-base">{item.q}</span>
                        <i class="ph ph-caret-down text-orange-500 text-xl flex-shrink-0 transition-transform duration-300"></i>
                    </button>
                    <div class="faq-body hidden px-7 pb-6">
                        <p class="text-gray-600 leading-relaxed">{item.a}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ CTA -->
<section class="bg-gray-900 py-20 relative overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 bg-orange-500/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-orange-500/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center reveal">
        <h2 class="text-4xl md:text-5xl font-extrabold font-heading text-white mb-5">{text.ctaTitle}</h2>
        <p class="text-gray-400 text-xl mb-10 leading-relaxed">{text.ctaDesc}</p>
        <a href={`${base}${pfx}contacts`} class="inline-block bg-orange-500 hover:bg-orange-600 text-white px-10 py-5 rounded-2xl font-bold text-lg transition-all hover:scale-105 shadow-2xl shadow-orange-500/30 btn-pulse">
            {text.ctaBtn}
        </a>
    </div>
</section>

</Layout>

<script is:inline>
function openWorksLightbox(src, label, sub) {
    const lb = document.getElementById('works-lightbox');
    document.getElementById('works-lb-img').src = src;
    document.getElementById('works-lb-label').textContent = label;
    document.getElementById('works-lb-sub').textContent = sub;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
}
function closeWorksLightbox() {
    const lb = document.getElementById('works-lightbox');
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeWorksLightbox(); });

function toggleFaq(btn) {
    const body  = btn.nextElementSibling;
    const icon  = btn.querySelector('i');
    const open  = !body.classList.contains('hidden');
    document.querySelectorAll('.faq-body').forEach(b => b.classList.add('hidden'));
    document.querySelectorAll('.faq-btn i').forEach(i => i.style.transform = '');
    if (!open) {
        body.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
    }
}
</script>
